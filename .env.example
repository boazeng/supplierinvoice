# === סביבה ===
ENV=development

# === שרת ===
HOST=0.0.0.0
PORT=8000

# === Priority ERP ===
PRIORITY_URL=https://YOUR_SERVER/odata/Priority/tabula.ini/YOUR_COMPANY/
PRIORITY_USER=your_user
PRIORITY_PASS=your_password
PRIORITY_COMPANY=your_company
PRIORITY_SYNC_INTERVAL_MINUTES=60

# === Anthropic AI ===
ANTHROPIC_API_KEY=your_anthropic_api_key
AI_MODEL=claude-opus-4-5

# === אימייל (אופציונלי) ===
EMAIL_HOST=
EMAIL_PORT=993
EMAIL_USER=
EMAIL_PASS=
EMAIL_FOLDER=INBOX
